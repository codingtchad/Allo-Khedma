# Database
DATABASE_URL=postgresql://allo_khedma_user:password_secure@localhost:5432/allo_khedma

# Security
SECRET_KEY=votre_secret_key_tres_long_et_aleatoire_changez_cette_valeur
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin par défaut
ADMIN_EMAIL=admin@allokhedma.com
ADMIN_PASSWORD=Admin123!ChangeMe

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Cloudinary (optionnel - pour les images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Environment
ENVIRONMENT=development
